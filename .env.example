# Copy this file to ".env" and fill in your values. .env is gitignored.

# Your Deezer ARL cookie (SECRET -- never commit this).
# How to get it: log in at https://www.deezer.com, open DevTools (F12) ->
# Application/Storage -> Cookies -> https://www.deezer.com -> copy the value
# of the "arl" cookie.
DEEMIX_ARL=

# deemix-gui server base URL
DEEMIX_SERVER=http://127.0.0.1:6595

# Default quality when neither --flac nor --mp3 is passed: flac or mp3
DEEMIX_QUALITY=flac
